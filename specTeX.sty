% specTeX.sty — LaTeX style for Praat spectrogram/waveform figures
%
% Provides formatting support for acoustic figures exported by
% specTeX.praat. Use with XeLaTeX or LuaLaTeX (fontspec requirement).
%
% 2013–2026 Dan Brenner
%~%~%~%~%~%~%~%~%~%~%~%~%~%~%~%~%~%~%~%

\ProvidesPackage{specTeX}
\usepackage{graphicx}
\usepackage{tikz}
\usepackage{calc}
\usepackage{fontspec}
\usetikzlibrary{shapes,calc}

% Dimensions — override these in your preamble with \setlength as needed
\newlength\labheight
\setlength\labheight{1.5em}
\newlength\intheight
\setlength\intheight{1.5em}
\newlength\inttextboxsep
\setlength\inttextboxsep{1pt}
\newlength\imagewidth
\setlength\imagewidth{\textwidth - 2\labheight}
\newlength\imageheight
\setlength\imageheight{4cm}
\newlength\dashing
\setlength\dashing{2pt}
\newlength\xunit
\newlength\yunittop
\newlength\yunitbottom

% IPA font command — uses Doulos SIL if available, falls back to default font
\IfFontExistsTF{Doulos SIL}{%
	\newfontfamily\doulosfont{Doulos SIL}%
	\newcommand\ipa[1]{{\doulosfont #1}}%
}{%
	\PackageWarning{specTeX}{Doulos SIL not found, IPA text will use the default font}%
	\newcommand\ipa[1]{#1}%
}

% Set to 1 to extend interval boundary lines into the waveform, 0 to keep above
\newcommand\dashintoimage[0]{1}

% Main command: include a specTeX-generated figure data file.
% Usage: \begin{tikzpicture}\specfigure{myfile.tex}\end{tikzpicture}
\newcommand\specfigure[1]{%
	\input{#1}%
}
